rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Helper function to check if the user is authenticated
    function isAuthenticated() {
      return request.auth != null;
    }

    // Helper function to check if the user is the owner of the document
    function isOwner(uid) {
      return isAuthenticated() && request.auth.uid == uid;
    }

    // Helper function to check if the user has administrative privileges based on email pattern
    function isAdmin() {
      return isAuthenticated() && (
        request.auth.token.email == 'admin@aeva.com' ||
        request.auth.token.email.matches('.*admin.*')
      );
    }

    // Secure all user-specific data under their uid document and sub-collections
    match /users/{uid} {
      allow read, write: if isOwner(uid) || isAdmin();

      // Allow access to all nested subcollections (daily_logs, clinical_screening, etc.)
      match /{document=**} {
        allow read, write: if isOwner(uid) || isAdmin();
      }
    }

    // Allow authenticated users to read and create social posts, and update reactions
    match /social_posts/{postId} {
      allow read, create: if isAuthenticated();
      allow update: if isAuthenticated() && (
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['likes', 'hugs'])
      ) || isAdmin();
      allow delete: if isAdmin();
    }
  }
}
